<?xml version="1.0"?>
<model>
  <name>holonomic_robot</name>
  <version>1.0</version>
  <sdf version="1.9">model.sdf</sdf>

  <author>
    <name>autonav-gail-sac</name>
  </author>

  <description>
    Holonomic ground robot for GAIL+SAC navigation training.
    Drives via geometry_msgs/Twist on /cmd_vel:
      linear.x  -> body-frame forward/back velocity (vx_body)
      linear.y  -> body-frame strafe velocity      (vy_body)
      angular.z -> yaw rate                        (omega)
    Publishes a 360-degree 2D LiDAR scan on /scan and odometry on /odom.
  </description>
</model>
